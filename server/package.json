{
  "name": "eega-trust-server",
  "version": "1.0.0",
  "description": "Backend server for EEGA Trust CRM",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation nodemon server.js",
    "setup": "node setup.js",
    "test:auth": "curl -X POST http://localhost:5000/api/auth/login -H \"Content-Type: application/json\" -d '{\"email\":\"admin@eega.com\",\"password\":\"admin123\"}'",
    "clean": "rm -rf node_modules package-lock.json && npm install"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "handlebars": "^4.7.8",
    "jsonwebtoken": "^9.0.0",
    "moment": "^2.29.4",
    "mongoose": "^8.0.0",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.1",
    "nodemailer-sendgrid": "^1.0.3",
    "pdfkit": "^0.17.2"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "nodemon": "^3.0.0"
  }
